{{- $hasRoot := false -}}
{{- $useHomeManager := false -}}
{{- $createSymlinks := false -}}
{{- $use_scoop := false -}}
{{- $isWSL := false -}}
{{- $userName := .chezmoi.username -}}
{{- $os_id := .chezmoi.os -}}
{{- /* linux-specific */ -}}
{{- if eq .chezmoi.os "linux" -}}
  {{- if hasKey .chezmoi.osRelease "id" -}}
    {{- $os_id = printf "%s-%s" .chezmoi.os .chezmoi.osRelease.id -}}
  {{- end -}}
  {{- $hasRoot = promptBoolOnce . "has_root" "Do you have root access via sudo?" true -}}
  {{- if $hasRoot -}}
    {{- $useHomeManager = promptBoolOnce . "use_home_manager" "Bootstrap Nix and run home-manager?" true -}}
  {{- end -}}
  {{- $isWSL = .chezmoi.kernel.osrelease | lower | contains "microsoft" | or (.chezmoi.kernel.osrelease | lower | contains "wsl") -}}
{{- end -}}
{{- /* windows-specific */ -}}
{{- if eq .chezmoi.os "windows" -}}
    {{- $createSymlinks = promptBoolOnce . "create_symlinks" "Use Windows symlinks? (requires manual setup, see README.md)" true -}}
    {{- $use_scoop = promptBoolOnce . "use_scoop" "Install Scoop and packages?" true -}}
{{- end -}}
{{- if eq .chezmoi.os "windows" -}}
  {{- if contains "\\" .chezmoi.username -}}
    {{- $userName = .chezmoi.username | splitList "\\" | last -}}
  {{- end -}}
{{- end -}}
{{- /* system theme detection */ -}}
{{- $activeTheme := "paradise-ed" -}}
{{- $scheme := "" -}}
{{- if eq .chezmoi.os "linux" -}}
  {{- $out := output "sh" "-c" "busctl call --user org.freedesktop.portal.Desktop /org/freedesktop/portal/desktop org.freedesktop.portal.Settings Read ss org.freedesktop.appearance color-scheme 2>/dev/null || true" -}}
  {{- $out = trim $out -}}
  {{- if contains " 1" $out -}}{{- $scheme = "dark" -}}{{- end -}}
  {{- if contains " 2" $out -}}{{- $scheme = "light" -}}{{- end -}}
{{- else if eq .chezmoi.os "windows" -}}
  {{- $out := output "cmd.exe" "/c" "reg query HKCU\\Software\\Microsoft\\Windows\\CurrentVersion\\Themes\\Personalize /v AppsUseLightTheme 2>nul || echo 0x1" -}}
  {{- $out = trim $out -}}
  {{- if contains "0x0" $out -}}{{- $scheme = "dark" -}}{{- end -}}
  {{- if contains "0x1" $out -}}{{- $scheme = "light" -}}{{- end -}}
{{- end -}}
{{- if eq $scheme "dark" -}}
  {{- $activeTheme = "paradise-ed" -}}
{{- else if eq $scheme "light" -}}
  {{- $activeTheme = "flexoki-light" -}}
{{- end -}}
encryption = "age"
mode = "file"

[age]
identity = "~/.config/age/keys.txt"
recipient = "age1y3gurxw9qm55agwwqzlqe5xtp0476q48mga5t53nrpp7ckqjh44qkfje6j"

[data]
# dark: paradise-ed, gruvbox-material-dark, kanagawa-wave, kape
# light: gruvbox-light, papercolor-light, flexoki-light
active_theme = "{{ $activeTheme }}"
os_id = "{{ $os_id }}"
user_name = "{{ $userName }}"
{{- if eq .chezmoi.os "linux" }}
has_root = {{ $hasRoot }}
use_home_manager = {{ $useHomeManager }}
is_wsl = {{ $isWSL }}
{{- end }}
{{- if eq .chezmoi.os "windows" }}
create_symlinks = {{ $createSymlinks }}
use_scoop = {{ $use_scoop }}
{{- end }}

[diff]
exclude = ["scripts", "remove"]
