{{- $p := index .theme.palettes .active_theme -}}
{
  "defs": {
    "bg": "{{ $p.background }}",
    "black": "{{ $p.ext.comment }}",
    "red": "{{ $p.normal.red }}",
    "green": "{{ $p.normal.green }}",
    "yellow": "{{ $p.normal.yellow }}",
    "blue": "{{ $p.normal.blue }}",
    "magenta": "{{ $p.normal.magenta }}",
    "cyan": "{{ $p.normal.cyan }}",
    "white": "{{ $p.normal.white }}",
    "brblack": "{{ $p.ext.selection }}",
    "brwhite": "{{ $p.ext.subtle }}",
    "bryellow": "{{ $p.ext.extra_yellow }}",
    "brblue": "{{ $p.ext.extra_blue }}",
    "surfaceBg": "{{ $p.ext.surface }}",
    "elementBg": "{{ $p.ext.element }}",
    "diffAddFg": "{{ $p.diff.add_fg }}",
    "diffRemoveFg": "{{ $p.diff.delete_fg }}",
    "diffHunkFg": "{{ $p.diff.hunk_fg }}",
    "diffHighlightAddFg": "{{ $p.diff.highlight_add_fg }}",
    "diffHighlightRemoveFg": "{{ $p.diff.highlight_remove_fg }}",
    "diffAddBg": "{{ $p.diff.add_bg }}",
    "diffRemoveBg": "{{ $p.diff.delete_bg }}"
  },
  "theme": {
    "primary": { "dark": "blue", "light": "blue" },
    "secondary": { "dark": "brblue", "light": "brblue" },
    "accent": { "dark": "cyan", "light": "cyan" },
    "error": { "dark": "red", "light": "red" },
    "warning": { "dark": "yellow", "light": "yellow" },
    "success": { "dark": "green", "light": "green" },
    "info": { "dark": "blue", "light": "blue" },
    "text": { "dark": "white", "light": "white" },
    "textMuted": { "dark": "brwhite", "light": "brwhite" },
    "background": { "dark": "bg", "light": "bg" },
    "backgroundPanel": { "dark": "surfaceBg", "light": "surfaceBg" },
    "backgroundElement": { "dark": "elementBg", "light": "elementBg" },
    "border": { "dark": "black", "light": "black" },
    "borderActive": { "dark": "blue", "light": "blue" },
    "borderSubtle": { "dark": "brblack", "light": "brblack" },
    "diffAdded": { "dark": "diffAddFg", "light": "diffAddFg" },
    "diffRemoved": { "dark": "diffRemoveFg", "light": "diffRemoveFg" },
    "diffContext": { "dark": "brwhite", "light": "brwhite" },
    "diffHunkHeader": { "dark": "diffHunkFg", "light": "diffHunkFg" },
    "diffHighlightAdded": { "dark": "diffHighlightAddFg", "light": "diffHighlightAddFg" },
    "diffHighlightRemoved": { "dark": "diffHighlightRemoveFg", "light": "diffHighlightRemoveFg" },
    "diffAddedBg": { "dark": "diffAddBg", "light": "diffAddBg" },
    "diffRemovedBg": { "dark": "diffRemoveBg", "light": "diffRemoveBg" },
    "diffContextBg": { "dark": "surfaceBg", "light": "surfaceBg" },
    "diffLineNumber": { "dark": "black", "light": "black" },
    "diffAddedLineNumberBg": { "dark": "diffAddBg", "light": "diffAddBg" },
    "diffRemovedLineNumberBg": { "dark": "diffRemoveBg", "light": "diffRemoveBg" },
    "markdownText": { "dark": "white", "light": "white" },
    "markdownHeading": { "dark": "blue", "light": "blue" },
    "markdownLink": { "dark": "brblue", "light": "brblue" },
    "markdownLinkText": { "dark": "cyan", "light": "cyan" },
    "markdownCode": { "dark": "green", "light": "green" },
    "markdownBlockQuote": { "dark": "black", "light": "black" },
    "markdownEmph": { "dark": "yellow", "light": "yellow" },
    "markdownStrong": { "dark": "bryellow", "light": "bryellow" },
    "markdownHorizontalRule": { "dark": "black", "light": "black" },
    "markdownListItem": { "dark": "blue", "light": "blue" },
    "markdownListEnumeration": { "dark": "cyan", "light": "cyan" },
    "markdownImage": { "dark": "brblue", "light": "brblue" },
    "markdownImageText": { "dark": "cyan", "light": "cyan" },
    "markdownCodeBlock": { "dark": "surfaceBg", "light": "surfaceBg" },
    "syntaxComment": { "dark": "black", "light": "black" },
    "syntaxKeyword": { "dark": "magenta", "light": "magenta" },
    "syntaxFunction": { "dark": "blue", "light": "blue" },
    "syntaxVariable": { "dark": "cyan", "light": "cyan" },
    "syntaxString": { "dark": "green", "light": "green" },
    "syntaxNumber": { "dark": "yellow", "light": "yellow" },
    "syntaxType": { "dark": "magenta", "light": "magenta" },
    "syntaxOperator": { "dark": "brblue", "light": "brblue" },
    "syntaxPunctuation": { "dark": "white", "light": "white" }
  }
}
